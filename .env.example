# Root environment example for local development

# Client URL used by backend CORS and redirects
CLIENT_URL=http://localhost:5173

# Backend settings
PORT=5000
JWT_SECRET=change-this-to-a-long-random-secret-in-production
MONGODB_URI=mongodb://127.0.0.1:27017/nayakar

# Optional Razorpay credentials for live payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin seed user (optional)
ADMIN_EMAIL=admin@nayakarpure.com
ADMIN_PASSWORD=Admin@123456
